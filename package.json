{
  "name": "klassrun-api",
  "version": "0.1.0",
  "description": "Klassrun API — the AI-powered school operating system for Nigerian schools",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "postinstall": "prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:seed:super-admin": "node scripts/seed-super-admin.js",
    "db:studio": "npx prisma studio",
    "test:slug": "node scripts/test-slug.js",
    "test:auth": "node scripts/test-auth.js",
    "build": "prisma generate"
  },
  "keywords": [
    "edtech",
    "nigeria",
    "school-management",
    "ai",
    "saas"
  ],
  "author": "Klassrun Technologies Ltd",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.1",
    "@prisma/adapter-pg": "^7.7.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemon": "^3.1.14",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "resend": "^4.8.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@prisma/client": "^7.8.0",
    "prisma": "^7.7.0"
  }
}
