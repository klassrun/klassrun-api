# ──────────────────────────────────────────────────────────────────────────
#  Klassrun API — environment variables
#
#  Copy this file to `.env` and fill in real values.
#  Never commit `.env` (it's gitignored).
# ──────────────────────────────────────────────────────────────────────────

# ── Database ──
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/klassrun_db"

# ── Auth ──
JWT_SECRET="generate-with-node-e-console-log-require-crypto-randomBytes-32-toString-hex"
JWT_EXPIRES_IN="7d"

# ── Server ──
PORT=4000
NODE_ENV=development

# ── Frontend / CORS ──
# Used to build invite links and welcome email portal URLs.
# In production: https://app.klassrun.com
FRONTEND_URL=http://localhost:3000

# Comma-separated list of allowed origins for CORS.
# Production should include: https://app.klassrun.com,https://klassrun.com
# Subdomains under klassrun.com are auto-allowed via regex in app.js.
ALLOWED_ORIGINS=http://localhost:3000

# Used by buildPortalUrl helper. Production: klassrun.com
PORTAL_BASE_DOMAIN=klassrun.com

# ── Email (Resend) ──
# If RESEND_API_KEY is missing, the email module runs in STUB MODE
# (logs emails to console instead of sending). Safe for local dev.
# Production MUST have this set.
RESEND_API_KEY=re
EMAIL_FROM="Klassrun <info@klassrun.com>"
EMAIL_REPLY_TO="info@klassrun.com"

# ── SUPER_ADMIN seed ──
# Used by `npm run db:seed:super-admin` to create platform-wide admin users.
# In production, set these in Railway's environment variables.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_FIRST_NAME=
SUPER_ADMIN_LAST_NAME=

# ── External APIs (coming soon) ──
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001  # optional override
PAYSTACK_SECRET_KEY=
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
