generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  BURSAR
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum ContentType {
  LESSON_NOTE
  EXAM_QUESTION
  SCHEME_OF_WORK
}

enum SessionTerm {
  FIRST
  SECOND
  THIRD
}

// NEW — controls whether a school's portal is reachable
enum SchoolStatus {
  PROVISIONING // Domain being set up on Vercel
  ACTIVE // Normal operating state
  SUSPENDED // Manually paused by super admin
  EXPIRED // Subscription lapsed; redirected to billing
}

// ─────────────────────────────────────────────────────────────────────────────
//  CORE TABLES
// ─────────────────────────────────────────────────────────────────────────────

model School {
  id       String  @id @default(uuid())
  name     String
  address  String?
  state    String?
  logoUrl  String?
  rcNumber String?

  // ── NEW: multi-tenancy fields ──
  slug         String       @unique // greenfield-academy → greenfield-academy.klassrun.com
  customDomain String?      @unique // future white-label tier
  status       SchoolStatus @default(PROVISIONING)
  slugLockedAt DateTime? // set after 30 days of activity
  // ───────────────────────────────

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Batch 2 Phase 1 — school profile fields ──
  phone        String?
  contactEmail String?
  motto        String?

  // Relations
  users        User[]
  classes      Class[]
  subjects     Subject[]
  lessonNotes  LessonNote[]
  assessments  Assessment[]
  questionBank QuestionBankEntry[]
  subscription Subscription?
  sessions     AcademicSession[]

  schemesOfWork  SchemeOfWork[] // batch-3-phase-2-scheme-model
  @@index([slug])
  @@index([status])
  students      Student[]
  resultEntries ResultEntry[]
  reportCards   ReportCard[] // ops-1-rel-school
  attendanceRecords  AttendanceRecord[] // ops-2-rel-school
  behaviourRecords   BehaviourRecord[] // ops-2-rel-school
  reportCardComments ReportCardComment[] // ops-2-rel-school
  promotionRecords   PromotionRecord[] // ops-3-rel-school
  feeRecords         FeeRecord[] // ops-4-rel-school
  @@map("schools")
}

model User {
  id               String               @id @default(uuid())
  email            String               @unique
  password         String
  firstName        String
  lastName         String
  role             Role                 @default(TEACHER)
  isActive         Boolean              @default(true)
  inviteToken      String?              @unique
  inviteAccepted   Boolean              @default(false)
  inviteExpiresAt  DateTime?
  authEvents       AuthEvent[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  revokedAt        DateTime?
  failedLoginCount Int                  @default(0)
  lockedUntil      DateTime?
  passwordResets   PasswordResetToken[]

  // Relations
  schoolId    String? // CHANGED: nullable to support SUPER_ADMIN (platform-wide users)
  school      School?      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  lessonNotes LessonNote[]
  assessments Assessment[]
  subjects    Subject[]            @relation("SubjectTeacher")

  schemesOfWork  SchemeOfWork[] // batch-3-phase-2-scheme-model
  @@index([schoolId]) // NEW: faster tenant-scoped queries
  @@map("users")
}

model AcademicSession {
  id          String      @id @default(uuid())
  name        String // e.g. "2025/2026"
  currentTerm SessionTerm @default(FIRST)
  isCurrent   Boolean     @default(false)
  createdAt   DateTime    @default(now())

  // Relations
  schoolId    String
  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  lessonNotes LessonNote[]
  assessments Assessment[]

  schemesOfWork  SchemeOfWork[] // batch-3-phase-2-scheme-model
  @@unique([schoolId, name])
  @@index([schoolId]) // NEW
  startDate   DateTime?
  endDate     DateTime?
  updatedAt   DateTime @updatedAt @default(now())

  resultEntries ResultEntry[]
  reportCards   ReportCard[] // ops-1-rel-session
  attendanceRecords  AttendanceRecord[] // ops-2-rel-session
  behaviourRecords   BehaviourRecord[] // ops-2-rel-session
  reportCardComments ReportCardComment[] // ops-2-rel-session
  promotionRecords   PromotionRecord[] // ops-3-rel-session
  feeRecords         FeeRecord[] // ops-4-rel-session
  @@map("academic_sessions")
}

model Class {
  id        String   @id @default(uuid())
  name      String // e.g. "JSS 1", "SS 2"
  level     String? // "junior" or "senior"
  createdAt DateTime @default(now())

  // Relations
  schoolId    String
  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subjects    Subject[]
  lessonNotes LessonNote[]
  assessments Assessment[]

  archivedAt DateTime? // batch-2c-phase-2-class-archive
  updatedAt  DateTime @updatedAt @default(now())
  schemesOfWork  SchemeOfWork[] // batch-3-phase-2-scheme-model
  @@unique([schoolId, name])
  @@index([schoolId]) // NEW
  @@index([schoolId, archivedAt])
  students Student[] // ops-1-rel-class
  promotionsFrom PromotionRecord[] @relation("PromotionFrom") // ops-3-rel-class-from
  promotionsTo   PromotionRecord[] @relation("PromotionTo") // ops-3-rel-class-to
  @@map("classes")
}

model Subject {
  id        String   @id @default(uuid())
  name      String // e.g. "Mathematics", "English Language"
  createdAt DateTime @default(now())

  // Relations
  schoolId     String
  school       School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId      String
  class        Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacherId    String?
  // hotfix-batch-2c-phase-3b-subject-teacher-relation
  teacher      User?               @relation("SubjectTeacher", fields: [teacherId], references: [id])
  lessonNotes  LessonNote[]
  assessments  Assessment[]
  questionBank QuestionBankEntry[]

  archivedAt DateTime? // batch-2c-phase-3a-subject-archive
  updatedAt  DateTime  @updatedAt @default(now())
  schemesOfWork  SchemeOfWork[] // batch-3-phase-2-scheme-model
  @@unique([schoolId, classId, name])
  @@index([schoolId]) // NEW
  @@index([schoolId, archivedAt])
  resultEntries ResultEntry[] // ops-1-rel-subject
  @@map("subjects")
}

// ─────────────────────────────────────────────────────────────────────────────
//  CONTENT TABLES
// ─────────────────────────────────────────────────────────────────────────────

model LessonNote {
  id           String      @id @default(uuid())
  topic        String
  week         Int?
  content      Json
  contentType  ContentType @default(LESSON_NOTE)
  sessionStamp String // e.g. "2025/2026 · Term 2"
  pdfUrl       String?
  isEdited     Boolean     @default(false)
  editHistory  Json?
  deletedAt    DateTime? // batch-3-phase-1-lesson-note-deleted
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Relations
  schoolId  String
  school    School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   User            @relation(fields: [teacherId], references: [id])
  classId   String
  class     Class           @relation(fields: [classId], references: [id])
  subjectId String
  subject   Subject         @relation(fields: [subjectId], references: [id])
  sessionId String
  session   AcademicSession @relation(fields: [sessionId], references: [id])

  @@index([schoolId]) // NEW
  @@index([schoolId, subjectId, classId]) // NEW: dashboard queries
  @@map("lesson_notes")
}

model Assessment {
  id           String      @id @default(uuid())
  title        String
  questions    Json
  totalMarks   Int?
  duration     Int?
  contentType  ContentType @default(EXAM_QUESTION)
  sessionStamp String
  pdfUrl       String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Relations
  schoolId  String
  school    School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   User            @relation(fields: [teacherId], references: [id])
  classId   String
  class     Class           @relation(fields: [classId], references: [id])
  subjectId String
  subject   Subject         @relation(fields: [subjectId], references: [id])
  sessionId String
  session   AcademicSession @relation(fields: [sessionId], references: [id])

  // NEW — used questions for this assessment, used by deduplication logic
  usedQuestionIds Json?
  deletedAt    DateTime? // batch-3-phase-3a-assessment-deleted // Array of QuestionBankEntry ids

  @@index([schoolId, deletedAt]) // batch-3-phase-3a-assessment-deleted-idx
  @@index([schoolId]) // NEW
  @@map("assessments")
}

model QuestionBankEntry {
  id           String  @id @default(uuid())
  question     String
  options      Json?
  answer       String?
  questionType String // "objective", "theory", "practical"
  difficulty   String?
  topic        String
  waecAligned  Boolean @default(false)

  // ── NEW: deduplication & retention hooks ──
  fingerprint String // normalized hash of question content
  timesUsed   Int       @default(0) // increments when used in an Assessment
  lastUsedAt  DateTime?
  // ──────────────────────────────────────────

  createdAt DateTime @default(now())

  // Relations
  schoolId  String
  school    School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  @@unique([schoolId, fingerprint]) // NEW: same question can't exist twice for one school
  @@index([schoolId]) // NEW
  @@index([schoolId, subjectId, topic]) // NEW: filtering question bank
  @@map("question_bank")
}

// ─────────────────────────────────────────────────────────────────────────────
//  BILLING
// ─────────────────────────────────────────────────────────────────────────────

model Subscription {
  id             String             @id @default(uuid())
  plan           String // "starter", "standard", "premium"
  status         SubscriptionStatus @default(TRIAL)
  startDate      DateTime           @default(now())
  endDate        DateTime
  trialEndsAt    DateTime? // NEW: powers the 14-day trial
  paystackSubId  String?
  paystackCustId String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  // Relations
  schoolId String @unique
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ─────────────────────────────────────────────────────────────────────────────
//  CURRICULUM (shared, not per-school)
// ─────────────────────────────────────────────────────────────────────────────

model CurriculumTopic {
  id         String      @id @default(uuid())
  subject    String
  className  String
  term       SessionTerm
  week       Int
  topic      String
  subtopics  Json?
  objectives Json?
  source     String      @default("NERDC")

  @@unique([subject, className, term, week])
  @@map("curriculum_topics")
}

// ─────────────────────────────────────────────────────────────────────────────
//  NEW — RESERVED SLUGS
//  Blocks system-critical names from being claimed as school subdomains.
//  Seeded via prisma/seed.js — never edit at runtime.
// ─────────────────────────────────────────────────────────────────────────────

model ReservedSlug {
  slug      String   @id
  reason    String?
  createdAt DateTime @default(now())

  @@map("reserved_slugs")
}

enum AuthEventType {
  SIGNUP_SUCCESS
  LOGIN_SUCCESS
  LOGIN_FAILED
  INVITE_SENT
  INVITE_ACCEPTED
  INVITE_FAILED
  INVITE_RESENT
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  SUPER_ADMIN_SEEDED
  PASSWORD_RESET_FAILED
  TEACHER_REVOKED
  TEACHER_REINSTATED
  TEACHER_PASSWORD_RESET
  ACCOUNT_LOCKED
}

enum AcademicEventType {
  // batch-2c-phase-1-academic-events
  SESSION_CREATED
  SESSION_MADE_CURRENT
  TERM_ADVANCED
  // batch-2c-phase-2-class-archive
  CLASS_CREATED
  CLASS_UPDATED
  CLASS_ARCHIVED
  CLASS_RESTORED
  // batch-2c-phase-3a-subject-archive
  SUBJECT_CREATED
  SUBJECT_UPDATED
  SUBJECT_ARCHIVED
  SUBJECT_RESTORED
  // batch-2c-phase-3b-teacher-events
  SUBJECT_TEACHER_ASSIGNED
  SUBJECT_TEACHER_UNASSIGNED
  // batch-3-phase-1-lesson-events
  LESSON_NOTE_GENERATED
  LESSON_NOTE_EDITED
  LESSON_NOTE_DISCARDED

  // batch-3-phase-2-scheme-events
  SCHEME_GENERATED
  SCHEME_EDITED
  SCHEME_DISCARDED

  // batch-3-phase-3a-question-events
  QUESTION_GENERATED
  ASSESSMENT_EDITED
  ASSESSMENT_DISCARDED

  // ops-1-academic-events
  STUDENT_CREATED
  STUDENT_UPDATED
  STUDENT_ARCHIVED
  STUDENT_RESTORED
  RESULT_ENTERED
  REPORT_CARD_GENERATED
  REPORT_CARD_LOCKED
  // ops-2-academic-events
  ATTENDANCE_RECORDED
  BEHAVIOUR_RECORDED
  REPORT_CARD_COMMENT_GENERATED
  REPORT_CARD_COMMENT_EDITED
  // ops-3-academic-events
  PROMOTION_EXECUTED
  PROMOTION_REVERSED
  // ops-4-academic-events
  FEE_MARKED
  FEE_BULK_MARKED
}


model AuthEvent {
  id        String        @id @default(uuid())
  type      AuthEventType
  email     String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime      @default(now())

  userId   String?
  user     User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  schoolId String?

  @@index([type])
  @@index([email])
  @@index([userId])
  @@index([createdAt])
  @@map("auth_events")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  ipAddress String?
  userAgent String?

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model AcademicEvent {
  id        String            @id @default(uuid())
  type      AcademicEventType
  schoolId  String
  actorId   String?
  metadata  Json?
  createdAt DateTime          @default(now())

  @@index([schoolId])
  @@index([type])
  @@index([createdAt])
  @@map("academic_events")
}

// batch-3-phase-2-scheme-model
model SchemeOfWork {
  id           String      @id @default(uuid())
  title        String
  content      Json
  contentType  ContentType @default(SCHEME_OF_WORK)
  sessionStamp String
  pdfUrl       String?
  isEdited     Boolean     @default(false)
  editHistory  Json?
  deletedAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  schoolId  String
  school    School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   User            @relation(fields: [teacherId], references: [id])
  classId   String
  class     Class           @relation(fields: [classId], references: [id])
  subjectId String
  subject   Subject         @relation(fields: [subjectId], references: [id])
  sessionId String
  session   AcademicSession @relation(fields: [sessionId], references: [id])

  @@index([schoolId])
  @@index([schoolId, subjectId, classId])
  @@index([schoolId, deletedAt])
  @@map("schemes_of_work")
}


// ════════════════════════════════════════════════════════════════════════════
//  OPERATIONS 1 — Student spine + Results + Report cards
// ════════════════════════════════════════════════════════════════════════════
// ops-1-student-models
model Student {
  id              String    @id @default(uuid())
  admissionNumber String
  firstName       String
  lastName        String
  middleName      String?
  photoUrl        String?
  dateOfBirth     DateTime?
  gender          String?
  guardianName    String?
  guardianPhone   String?
  guardianEmail   String?

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId  String
  class    Class  @relation(fields: [classId], references: [id])

  results     ResultEntry[]
  reportCards ReportCard[]
  attendanceRecords  AttendanceRecord[] // ops-2-rel-student
  behaviourRecords   BehaviourRecord[] // ops-2-rel-student
  reportCardComments ReportCardComment[] // ops-2-rel-student
  promotionRecords   PromotionRecord[] // ops-3-rel-student
  feeRecords         FeeRecord[] // ops-4-rel-student

  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([schoolId, admissionNumber])
  @@index([schoolId])
  @@index([schoolId, archivedAt])
  @@index([schoolId, classId])
  @@map("students")
}

model ResultEntry {
  id        String      @id @default(uuid())
  term      SessionTerm
  ca1       Int         @default(0)
  ca2       Int         @default(0)
  objective Int         @default(0)
  theory    Int         @default(0)
  total     Int         @default(0)
  grade     String

  schoolId    String
  school      School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId   String
  subject     Subject         @relation(fields: [subjectId], references: [id])
  sessionId   String
  session     AcademicSession @relation(fields: [sessionId], references: [id])
  enteredById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, subjectId, sessionId, term])
  @@index([schoolId])
  @@index([schoolId, sessionId, term])
  @@map("result_entries")
}

model ReportCard {
  id       String      @id @default(uuid())
  term     SessionTerm
  snapshot Json
  pdfUrl   String?
  lockedAt DateTime?

  schoolId      String
  school        School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sessionId     String
  session       AcademicSession @relation(fields: [sessionId], references: [id])
  generatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, sessionId, term])
  @@index([schoolId])
  @@index([schoolId, sessionId, term])
  @@map("report_cards")
}


// ════════════════════════════════════════════════════════════════════════════
//  OPERATIONS 2 — Attendance + Behaviour + Report-card comments
// ════════════════════════════════════════════════════════════════════════════
// ops-2-models
model AttendanceRecord {
  id           String      @id @default(uuid())
  term         SessionTerm
  schoolOpened Int         @default(0)
  present      Int         @default(0)
  absent       Int         @default(0)

  schoolId    String
  school      School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sessionId   String
  session     AcademicSession @relation(fields: [sessionId], references: [id])
  enteredById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, sessionId, term])
  @@index([schoolId])
  @@index([schoolId, sessionId, term])
  @@map("attendance_records")
}

model BehaviourRecord {
  id      String      @id @default(uuid())
  term    SessionTerm
  ratings Json

  schoolId    String
  school      School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sessionId   String
  session     AcademicSession @relation(fields: [sessionId], references: [id])
  enteredById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, sessionId, term])
  @@index([schoolId])
  @@index([schoolId, sessionId, term])
  @@map("behaviour_records")
}

model ReportCardComment {
  id            String      @id @default(uuid())
  term          SessionTerm
  classTeacher  String?
  principal     String?
  source        String      @default("ai")
  aiModel       String?
  aiGeneratedAt DateTime?

  schoolId      String
  school        School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sessionId     String
  session       AcademicSession @relation(fields: [sessionId], references: [id])
  generatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, sessionId, term])
  @@index([schoolId])
  @@index([schoolId, sessionId, term])
  @@map("report_card_comments")
}


// ════════════════════════════════════════════════════════════════════════════
//  OPERATIONS 3 — Promotion
// ════════════════════════════════════════════════════════════════════════════
// ops-3-promotion-model
model PromotionRecord {
  id         String      @id @default(uuid())
  decision   String      // "PROMOTED" | "RETAINED"
  cumulative Float?      // cumulative average at decision time (null if no results)
  threshold  Float?      // min-average rule used for the run (record-keeping)
  uptoTerm   SessionTerm // term the cumulative was computed through

  schoolId    String
  school      School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sessionId   String
  session     AcademicSession @relation(fields: [sessionId], references: [id])
  fromClassId String
  fromClass   Class           @relation("PromotionFrom", fields: [fromClassId], references: [id], onDelete: Restrict)
  toClassId   String?
  toClass     Class?          @relation("PromotionTo", fields: [toClassId], references: [id], onDelete: Restrict)
  decidedById  String?
  reversedAt   DateTime?
  reversedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([schoolId, sessionId])
  @@index([studentId, sessionId])
  @@map("promotion_records")
}

// ════════════════════════════════════════════════════════════════════════════
//  OPERATIONS 4 — Fees (status-only, term-scoped)
// ════════════════════════════════════════════════════════════════════════════
// ops-4-fee-model
model FeeRecord {
  id     String      @id @default(uuid())
  term   SessionTerm
  status String      @default("UNPAID") // "PAID" | "UNPAID"

  schoolId   String
  school     School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId  String
  student    Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sessionId  String
  session    AcademicSession @relation(fields: [sessionId], references: [id])
  markedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, sessionId, term])
  @@index([schoolId])
  @@index([schoolId, sessionId, term])
  @@map("fee_records")
}
